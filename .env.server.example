# Express 服务端口
SERVER_PORT=3000

# 允许跨域来源，多个逗号分隔。留空表示开发模式全部允许。
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# 上传大小限制（字节），默认 10MB
UPLOAD_MAX_SIZE=10485760

# ===== 上游模型/聊天接口配置（你主要修改这里） =====
# openai: OpenAI兼容流式接口；deepseek: DeepSeek OpenAI兼容接口；sse_json: 你的后端已返回 data: {delta:...} 的SSE
UPSTREAM_MODE=openai

# 上游聊天接口地址
# openai 示例: https://api.openai.com/v1/chat/completions
# 智谱示例: https://open.bigmodel.cn/api/paas/v4/chat/completions
# deepseek 示例: https://api.deepseek.com/chat/completions
# sse_json 示例: http://localhost:8000/chat/stream
UPSTREAM_CHAT_URL=

# 上游鉴权（没有可留空）
UPSTREAM_API_KEY=

# 上游鉴权模式：auto | bearer | zhipu-jwt
# auto: 对 open.bigmodel.cn 且 key 形如 id.secret 时自动转 JWT
UPSTREAM_AUTH_MODE=auto

# openai 模式下的模型名称
UPSTREAM_MODEL=gpt-4o-mini

# 可选模型列表（逗号分隔），用于前端下拉可选项
UPSTREAM_MODELS=

# ===== DeepSeek 配置（UPSTREAM_MODE=deepseek 时生效） =====
# DeepSeek 接口基地址（代码会自动补 /chat/completions）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek API Key（推荐）
DEEPSEEK_API_KEY=

# DeepSeek 默认模型
DEEPSEEK_MODEL=deepseek-chat

# DeepSeek 可选模型列表（逗号分隔）
DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner

# 请求超时（毫秒）
UPSTREAM_TIMEOUT_MS=120000

# 采样参数（openai模式）
UPSTREAM_TEMPERATURE=1
UPSTREAM_TOP_P=1

# 系统提示词（openai模式）
UPSTREAM_SYSTEM_PROMPT=你是一个专业、简洁、准确的中文 AI 助手。

# 额外请求头（JSON字符串），用于接入企业网关
# 示例: {"x-api-key":"xxx","x-app-id":"demo"}
UPSTREAM_HEADERS_JSON=

# ===== MongoDB（会话与知识库） =====
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=chat_app

# ===== Embedding（语义检索必填） =====
# 阿里云百炼 OpenAI 兼容 Embedding 地址（固定）
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
# 阿里云 API Key（请在控制台复制真实 Key）
EMBEDDING_API_KEY=
# Embedding 模型名（示例：text-embedding-v1 或 text-embedding-v3）
EMBEDDING_MODEL=text-embedding-v1
EMBEDDING_ENCODING_FORMAT=float
EMBEDDING_BATCH_SIZE=16

# ===== 向量检索（Mongo 支持 $vectorSearch 时再开启） =====
MONGODB_VECTOR_SEARCH_ENABLED=false
MONGODB_VECTOR_INDEX_NAME=kb_chunks_vector_index
MONGODB_VECTOR_SEARCH_LIMIT=40
MONGODB_VECTOR_SEARCH_NUM_CANDIDATES=160

# ===== RAG 路由阈值 =====
RAG_ROUTE_MIN_CONFIDENCE=0.32
RAG_ROUTE_MIN_CONFIDENCE_TEXT=0.12
RAG_ROUTE_PINNED_BOOST_ENABLED=true

# ===== 入库并发 =====
KB_INGEST_CONCURRENCY=2
KB_INGEST_QUEUE_SIZE=80
